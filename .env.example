# wretool 랜딩 — 외부 서비스 설정 (WRE-6)
# 값은 비밀이 아니라 공개 식별자다. 빌드 타임에 주입된다.
# 미설정 시 src/config.ts 의 기본값을 사용한다.

# 대기자 폼 제출 엔드포인트 (AJAX/JSON 응답 권장)
#  - 기본값: FormSubmit(formsubmit.co) → leon@wrtn.io 인박스 수신(계정 불필요)
#  - Formspree 대시보드형으로 교체 예시:
# VITE_FORM_ENDPOINT=https://formspree.io/f/xxxxxxx

# 분석 제공자: goatcounter | plausible | (빈 값=비활성)
VITE_ANALYTICS_PROVIDER=goatcounter

# GoatCounter 집계 엔드포인트 (무쿠키·무료, 대시보드 https://wretool.goatcounter.com/)
VITE_GOATCOUNTER_ENDPOINT=https://wretool.goatcounter.com/count

# Plausible 사용 시 도메인 (provider=plausible 일 때만)
# VITE_PLAUSIBLE_DOMAIN=wretool.com
